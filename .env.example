# In local dev this is proxied by Vite (see vite.config.js `server.proxy`)
# to avoid CORS issues, so a relative path works.
# For a production build, point this at the real API origin, e.g.
# https://api.hiohealth.com/api — and make sure that origin sends
# Access-Control-Allow-Origin for your deployed frontend's domain.
VITE_API_BASE_URL=/api
